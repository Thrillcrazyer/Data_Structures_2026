      "source": [
        "def arrayMax(A:ArrayType, n:int) -> int:\n",
        "    currentMax=A[0]\n",
        "    for i in range(1, n):\n",
        "        if A[i] > currentMax:\n",
        "            currentMax = A[i]\n",
        "    return currentMax\n",
        "\n",
        "print(arrayMax(A, n))"
      ]
    }
